# ==============================================================================
# 아래 블록을 기존 .env.example 에 추가한 뒤,
# .env 로 복사(cp .env.example .env) 후 값을 수정하세요.
# ==============================================================================

# ===== PostgreSQL =====
# 로컬 개발용 기본값. 프로덕션에서는 반드시 변경 필요.
POSTGRES_USER=sisicallcall
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sisicallcall
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# 애플리케이션이 사용할 전체 연결 문자열 (asyncpg 권장)
DATABASE_URL=postgresql://sisicallcall:changeme@localhost:5432/sisicallcall

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ===== ChromaDB =====
# docker-compose.yml에서 호스트 포트 8001로 매핑됨 (FastAPI 8000 충돌 회피)
CHROMA_HOST=localhost
CHROMA_PORT=8001

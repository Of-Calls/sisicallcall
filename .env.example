# ============================================================
# 시시콜콜 환경변수 예시
# 이 파일을 복사해 .env 를 만들고 본인 값으로 채우세요.
# .env 는 절대 커밋하지 마세요.
# ============================================================

# --- Twilio ---
# Twilio 콘솔 > Account Info 에서 확인
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+821012345678

# --- ngrok (로컬 테스트용) ---
# ngrok 실행 후 생성된 URL 입력 (예: https://xxxx-xxx-xxx.ngrok-free.app)
# Twilio 콘솔 > Phone Numbers > Webhook URL 에도 동일하게 설정
BASE_URL=https://your-ngrok-url.ngrok-free.app

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Deepgram (STT) ---
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Cloud TTS ---
# 서비스 계정 JSON 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# --- PostgreSQL ---
POSTGRES_USER=sisicallcall
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sisicallcall
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sisicallcall:changeme@localhost:5432/sisicallcall

# --- Redis (개별 설정) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- App ---
ENV=development
LOG_LEVEL=INFO

# ============================================================
# MCP Connector + SaaS OAuth 연동 설정
# ============================================================

# --- OAuth 토큰 암호화 키 ---
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Google OAuth (Gmail + Calendar) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 콜백 URI (예: https://your-app.com/api/v1/oauth/google_gmail/callback)
GOOGLE_OAUTH_REDIRECT_URI=

# --- Slack OAuth ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# 콜백 URI (예: https://your-app.com/api/v1/oauth/slack/callback)
SLACK_REDIRECT_URI=

# --- Atlassian (Jira) OAuth ---
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# 콜백 URI (예: https://your-app.com/api/v1/oauth/jira/callback)
ATLASSIAN_REDIRECT_URI=

# --- Tenant Integration 저장 백엔드 ---
# memory (기본): 서버 재시작 시 초기화됨 — 단위 테스트용
# file:          JSON 파일 persist — 로컬 개발 OAuth 테스트 권장
TENANT_INTEGRATION_STORAGE=file
TENANT_INTEGRATION_FILE_PATH=.local/tenant_integrations.json

# --- MCP 동작 모드 ---
# true: 고객사 OAuth 토큰 우선 사용 (SaaS 프로덕션)
# false (기본): mock 또는 .env 계정 사용 (개발/테스트)
MCP_USE_TENANT_OAUTH=false

# true: tenant OAuth 미연결 시 .env 방식으로 폴백 허용
# false (기본): 미연결 시 skipped 반환 (strict SaaS 모드)
MCP_ALLOW_ENV_FALLBACK=false

# --- MCP .env 계정 설정 (개발/테스트 전용 fallback) ---
# Gmail
GMAIL_MCP_REAL=false
GMAIL_MANAGER_TO=manager@example.com
GMAIL_MCP_SERVER_URL=

# Calendar
CALENDAR_MCP_REAL=false
CALENDAR_DEFAULT_OWNER=owner@example.com
CALENDAR_DEFAULT_DURATION_MIN=30
CALENDAR_MCP_SERVER_URL=

# Slack
SLACK_MCP_REAL=false
SLACK_ALERT_CHANNEL=#alerts
SLACK_BOT_TOKEN=
SLACK_MCP_SERVER_URL=

# Jira
JIRA_MCP_REAL=false
JIRA_PROJECT_KEY=VOC
JIRA_ISSUE_TYPE=Bug
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_MCP_SERVER_URL=

# CompanyDB
COMPANY_DB_MCP_REAL=false
